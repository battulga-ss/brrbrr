// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

type Stats {
  int      Int
  physical Int
}

type Status {
  failed      Boolean
  completed   Boolean
  pending     Boolean
}

type Reward {
  reward_xp      Int
  reward_int     Int
  reward_physical Int
}

model user {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  name   String
  level  Int
  xp     Int 
  stats  Stats

  @@map("user")
}

model quest { 
  id      String  @id @default(auto()) @map("_id") @db.ObjectId
  status  Status
  title   String
  reward  Reward
  createdAt DateTime @default(now())
  @@map("quest")

}